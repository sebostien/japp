infix  _==_  1;
infix  _!=_  1;
infix  _||_  2;
infix  _&&_  2;
infixl _-_   2;
infixl _+_   2;
infixl _*_   3;
infixr !_    4;

const x = 1337 ;

fac : i64 -> i64 ;
fn fac n = match n {
  0 -> 1 ;
  n -> n * fac(n - 1) ;
} ;

fn main = {
  println(5 * 4 * 3 * 2 * 1 == fac(5));
  println(
    fac(5) == 5 * fac(4),
    fac(5) != fac(4),
    fac(20) == fac(2 * 10),
    100 - 10 * 5 == 50,
    2 + 2 * 4 == 1 && 1 + 9
  )
};
