==================================================
Single const int declaration
--------------------------------------------------

const hello = 1 ;

--------------------------------------------------

(Program
  (Const "hello"
    (Lit
      (Int 1)
    ):14..15
  )
)

==================================================
Single const bool declaration
--------------------------------------------------

const hello = true ;

--------------------------------------------------

(Program
  (Const "hello" 
    (Lit
      (Bool true)
    ):14..18
  )
)

==================================================
Multi const declaration
--------------------------------------------------

const one = false ;
const two = 1337 ;

--------------------------------------------------

(Program
  (Const "one"
    (Lit
      (Bool false)
    ):12..17
  )
  (Const "two"
    (Lit
     (Int 1337)
    ):32..36
  )
)

